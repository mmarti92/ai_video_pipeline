# Database connection string (CockroachDB / PostgreSQL)
# For CockroachDB Cloud, keep sslmode=verify-full.  The application
# automatically locates the system CA bundle; no manual cert download needed.
PG_CONNECTION_STRING=postgresql://user:password@host:port/dbname?sslmode=verify-full

# OpenAI API key for AI script generation
OPENAI_API_KEY=sk-...

# Output directory for generated videos (default: ./output)
OUTPUT_DIR=./output

# Pipeline settings
PIPELINE_BATCH_SIZE=10
PIPELINE_POLL_INTERVAL_SECONDS=60
